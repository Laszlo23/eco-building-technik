      fullDescription: 'Die JNOD A+++ Wärmepumpe ist unsere meistverkaufte Wärmepumpe für Einfamilienhäuser in Österreich. Mit Energieeffizienzklasse A+++ und COP bis 5.0 bietet sie maximale Einsparung.',
      specs: ['A+++', '12kW', 'R32', 'COP 5.0', 'WiFi'],
      price: '€ 4.299,00',
      priceValue: 4299,
      wholesalePrice: '€ 3.869,00',
      image: '/images/product-1.jpg',
      isTopProduct: true,
      rating: 4.9,
      reviews: 127
    },
    {
