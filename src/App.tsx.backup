    },
    {
      id: 37,
      category: 'Gas-Brennwert',
      name: 'Vaillant ecoTEC plus VCW - EMPFOHLEN',
      description: 'Empfohlenes Gas-Brennwertgerät für Heizung und Warmwasser. Energieklasse A+.',
