      specs: ['Brennwert', 'Heizung + WW', '20-35 kW', 'A+'],
      price: '€ 2.890,00',
      priceValue: 2890,
      wholesalePrice: '€ 2.601,00',
      image: '/images/product-2.jpg',
      isTopProduct: true,
